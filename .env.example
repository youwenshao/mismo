# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma)
# DATABASE_URL: pooled connection (port 6543) for app queries
# DIRECT_URL: direct connection (port 5432) for migrations - required by Prisma
DATABASE_URL=
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
ZAI_API_KEY=

# Mo defaults (env fallback when no DB config)
DEFAULT_MO_PROVIDER=deepseek
DEFAULT_MO_MODEL=deepseek-chat

# LiveKit (WebRTC)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# DocuSign
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=

# n8n Workflow Pipeline (Optional)
SLACK_ALERT_WEBHOOK_URL=          # Forward workflow failure alerts to Slack
SANDBOX_HOST=                    # Studio 3 hostname for remote sandbox
SANDBOX_PORT=5679                # Sandbox n8n port
N8N_MANAGED_URL=                 # For managed deployment (Option B)
N8N_MANAGED_API_KEY=             # For managed deployment (Option B)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_APP_URL=http://localhost:3001

# GSD Build Pipeline (optional - for n8n orchestrated builds)
# Local dev defaults; override for Docker deployments
# GSD_DEPENDENCY_URL=http://localhost:3010
# BMAD_VALIDATOR_URL=http://localhost:3011
# CONTRACT_CHECKER_URL=http://localhost:3012
# DB_ARCHITECT_URL=http://localhost:3001
# BACKEND_ENGINEER_URL=http://localhost:3002
# FRONTEND_DEVELOPER_URL=http://localhost:3003
# DEVOPS_AGENT_URL=http://localhost:3004
# ERROR_LOGGER_URL=http://localhost:3005
