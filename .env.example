# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma)
# DATABASE_URL: pooled connection (port 6543) for app queries
# DIRECT_URL: direct connection (port 5432) for migrations - required by Prisma
DATABASE_URL=
DIRECT_URL=

# Stripe (for international credit cards)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PaymentAsia (for HK local payment methods: FPS, AliPayHK, WeChat Pay HK, PayMe, Octopus)
# Get merchant account at: https://www.paymentasia.com/
PAYMENTASIA_API_URL=https://api.paymentasia.com/v1
PAYMENTASIA_MERCHANT_ID=
PAYMENTASIA_API_KEY=
PAYMENTASIA_WEBHOOK_SECRET=

# Payment Method Feature Flags (default: enabled)
# Set to "false" to disable specific payment methods
ENABLE_STRIPE_CARD=true
ENABLE_FPS=true
ENABLE_ALIPAYHK=true
ENABLE_WECHATPAY=true
ENABLE_PAYME=true
ENABLE_OCTOPUS=true

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
ZAI_API_KEY=

# Mo defaults (env fallback when no DB config)
DEFAULT_MO_PROVIDER=deepseek
DEFAULT_MO_MODEL=deepseek-chat

# LiveKit (WebRTC)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# DocuSign
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_DELIVERY_ORG=mismo-agency

# n8n Workflow Pipeline (Optional)
SLACK_ALERT_WEBHOOK_URL=          # Forward workflow failure alerts to Slack
SANDBOX_HOST=                    # Studio 3 hostname for remote sandbox
SANDBOX_PORT=5679                # Sandbox n8n port
N8N_MANAGED_URL=                 # For managed deployment (Option B)
N8N_MANAGED_API_KEY=             # For managed deployment (Option B)

# Admin Whitelist (SHA-256 hashes of admin emails, comma-separated)
# Generate: echo -n "email@example.com" | shasum -a 256 | awk '{print $1}'
ADMIN_EMAIL_HASHES=f39abdc4427c477d7287e04dab7265d9c114394129e64f03d41f903b98a831c5

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_APP_URL=http://localhost:3001

# GSD Build Pipeline (optional - for n8n orchestrated builds)
# Local dev defaults; override for Docker deployments
# GSD_DEPENDENCY_URL=http://localhost:3010
# BMAD_VALIDATOR_URL=http://localhost:3011
# CONTRACT_CHECKER_URL=http://localhost:3012
# DB_ARCHITECT_URL=http://localhost:3030
# BACKEND_ENGINEER_URL=http://localhost:3031
# FRONTEND_DEVELOPER_URL=http://localhost:3032
# DEVOPS_AGENT_URL=http://localhost:3033
# ERROR_LOGGER_URL=http://localhost:3034

# Mobile Build Pipeline (optional)
# MOBILE_SCAFFOLD_URL=http://localhost:3020
# MOBILE_FEATURE_URL=http://localhost:3021
# MOBILE_BUILD_ENGINEER_URL=http://localhost:3022
# STORE_SUBMISSION_URL=http://localhost:3023
# N8N_MOBILE_PIPELINE_WEBHOOK_URL=http://localhost:5678/webhook/mobile-build-pipeline

# Delivery Pipeline
# DELIVERY_AGENT_URL=http://localhost:3001  # Internal API base URL for delivery n8n nodes

# Repo Surgery Pipeline
REPO_SURGERY_WORKSPACE=/tmp/mismo-surgery
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# REPO_SURGERY_URL=http://localhost:3001    # Internal API base URL for n8n nodes
# SONARQUBE_URL=                            # Optional: SonarQube for enhanced static analysis
# SONARQUBE_TOKEN=                          # Optional: SonarQube auth token

# Hosting Transfer
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
RAILWAY_API_TOKEN=
RENDER_API_KEY=
# AWS_ACCESS_KEY_ID=                  # Mismo's AWS account (for sub-account creation)
# AWS_SECRET_ACCESS_KEY=
# GCP_SERVICE_ACCOUNT_JSON=
# TERRAFORM_BINARY_PATH=/usr/local/bin/terraform

# Build Machines (SSH access for iOS/Android builds)
STUDIO_2_SSH_HOST=                    # macOS machine for iOS builds
STUDIO_2_SSH_KEY=                     # SSH key path for Studio 2
STUDIO_3_SSH_HOST=                    # Machine for Android builds
STUDIO_3_SSH_KEY=                     # SSH key path for Studio 3

# Apple Developer (for iOS builds and TestFlight submission)
APPLE_TEAM_ID=
APPLE_API_KEY_ID=
APPLE_API_ISSUER_ID=
APPLE_API_KEY_PATH=

# Google Play (for Android builds and Play Console submission)
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=

# Expo (EAS Build)
EXPO_TOKEN=

# Communication System (Resend primary, SMTP fallback)
RESEND_API_KEY=
RESEND_FROM_EMAIL=updates@mismo.dev
SMTP_HOST=                        # Fallback SMTP host
SMTP_PORT=587                     # Fallback SMTP port
SMTP_USER=                        # Fallback SMTP user
SMTP_PASS=                        # Fallback SMTP password
COMMS_WEBHOOK_SECRET=             # HMAC secret to verify pg_net webhook calls

# Twilio (SMS + Phone alerts for P0 critical notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=               # Twilio phone number for outbound SMS/calls
ALERT_PHONE_NUMBER=               # Developer phone for P0 critical alerts
ALERT_EMAIL=                      # Developer email for P1+ alerts

# Farm Monitor
FARM_MONITOR_ENABLED=false
STUDIO_1_SSH_HOST=                # Studio 1 (control plane) hostname
STUDIO_1_SSH_KEY=                 # SSH key path for Studio 1
FARM_MONITOR_ALERT_WEBHOOK=       # Internal webhook URL for resource watchdogs
