generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String             @id @default(cuid())
  supabaseAuthId         String             @unique
  role                   Role               @default(CLIENT)
  hasCompletedOnboarding Boolean            @default(false)
  stripeCustomerId       String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  commissions            Commission[]
  interviewSessions      InterviewSession[]
  prdComments            PRDComment[]
  projects               Project[]
  reviewTasks            ReviewTask[]       @relation("AssignedEngineer")
  grantedGrants          UserGrant[]        @relation("GrantedBy")
  grants                 UserGrant[]        @relation("GrantRecipient")
}

model Project {
  id                String             @id @default(cuid())
  name              String
  status            ProjectStatus      @default(DISCOVERY)
  tier              ServiceTier
  safetyScore       SafetyTier         @default(GREEN)
  userId            String
  assignedEngId     String?
  contractSigned    Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  buildLogs         BuildLog[]
  contracts         Contract[]
  interviewSessions InterviewSession[]
  prd               PRD?
  user              User               @relation(fields: [userId], references: [id])
  reviewTasks       ReviewTask[]
  tokenUsages       TokenUsage[]
}

model PRD {
  id             String       @id @default(cuid())
  projectId      String       @unique
  content        Json
  userStories    Json
  apiSpec        Json?
  dataModel      String?
  archTemplate   ArchTemplate
  ambiguityScore Float        @default(0)
  lockedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  project        Project      @relation(fields: [projectId], references: [id])
  comments       PRDComment[]
}

model PRDComment {
  id        String   @id @default(cuid())
  prdId     String
  userId    String
  content   String
  section   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  prd       PRD      @relation(fields: [prdId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model InterviewSession {
  id          String    @id @default(cuid())
  userId      String
  projectId   String?
  state       Json
  transcript  Json
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime
  project     Project?  @relation(fields: [projectId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model Contract {
  id              String    @id @default(cuid())
  projectId       String
  type            String
  status          String    @default("PENDING")
  envelopeId      String?
  signedAt        DateTime?
  ipAcknowledged  Boolean   @default(false)
  ageAcknowledged Boolean   @default(false)
  aupAcknowledged Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id])
}

model ReviewTask {
  id          String    @id @default(cuid())
  projectId   String
  engineerId  String?
  type        String
  status      String    @default("PENDING")
  notes       String?
  slaDeadline DateTime
  claimedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  engineer    User?     @relation("AssignedEngineer", fields: [engineerId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model BuildLog {
  id        String   @id @default(cuid())
  projectId String
  stage     String
  status    String
  output    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
}

model TokenUsage {
  id        String   @id @default(cuid())
  projectId String
  feature   String
  tokens    Int
  cost      Float
  agent     String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
}

model ProjectArchetype {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  metadata    Json?        @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Commission  Commission[]
  DesignDNA   DesignDNA[]
}

model Commission {
  id               String            @id @default(cuid())
  clientEmail      String
  status           CommissionStatus  @default(DRAFT)
  prdJson          Json?
  archetypeId      String?
  paymentState     PaymentState      @default(UNPAID)
  stripeCustomerId String?
  userId           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  feasibilityScore Float?
  riskAssessment   Json?
  builds           Build[]
  clientPreference ClientPreference?
  archetype        ProjectArchetype? @relation(fields: [archetypeId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  credentials      Credential[]
  deliveries       Delivery[]
  feedbacks        Feedback[]
  hostingTransfers HostingTransfer[]
  maintenancePlan  MaintenancePlan?
  notifications    Notification[]
  payments         Payment[]
  repoSurgeries    RepoSurgery[]
}

model Build {
  id               String            @id @default(cuid())
  commissionId     String
  executionIds     Json              @default("[]")
  studioAssignment String?
  kimiqTokensUsed  Int               @default(0)
  githubUrl        String?
  vercelUrl        String?
  status           String            @default("PENDING")
  errorLogs        Json?
  failureCount     Int               @default(0)
  humanReview      Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  commission       Commission        @relation(fields: [commissionId], references: [id])
  deliveries       Delivery[]
  deliveryPackage  DeliveryPackage?
  hostingTransfers HostingTransfer[]
}

model Agent {
  id             String    @id @default(cuid())
  type           AgentType
  currentLoad    Int       @default(0)
  studioLocation String
  lastHeartbeat  DateTime  @default(now())
  status         String    @default("ACTIVE")
}

model DesignDNA {
  id                  String           @id @default(cuid())
  archetypeId         String
  tokens              Json             @default("{}")
  forbiddenPatterns   String[]
  componentReferences String[]
  archetype           ProjectArchetype @relation(fields: [archetypeId], references: [id])
}

model RepoSurgery {
  id               String            @id @default(cuid())
  commissionId     String?
  repoUrl          String
  branch           String            @default("main")
  surgeryBranch    String?
  status           RepoSurgeryStatus @default(INGESTING)
  changeRequest    String
  boundaryMap      Json?
  contracts        Json?
  impactReport     Json?
  validationGates  Json?
  confidenceScore  Float?
  prUrl            String?
  cloneDir         String?
  qdrantCollection String?
  errorLogs        Json?
  failureCount     Int               @default(0)
  humanReview      Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  commission       Commission?       @relation(fields: [commissionId], references: [id])
}

model HostingTransfer {
  id                    String          @id @default(cuid())
  commissionId          String
  buildId               String?
  provider              HostingProvider
  status                TransferStatus  @default(PENDING_PAYMENT)
  stripePaymentIntentId String?         @unique
  paymentConfirmedAt    DateTime?
  deploymentUrl         String?
  deploymentConfig      Json?
  deploymentOutput      Json?
  clientAccountId       String?
  clientCredentials     Json?
  credentialNonce       String?
  credentialKeyId       String?
  transferOutput        Json?
  monitoringEnabled     Boolean         @default(false)
  monitoringUntil       DateTime?
  lastHealthCheck       DateTime?
  healthStatus          Json?
  errorLogs             Json?
  failureCount          Int             @default(0)
  retryCount            Int             @default(0)
  idempotencyKey        String?         @unique
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  paymentId             String?
  build                 Build?          @relation(fields: [buildId], references: [id])
  commission            Commission      @relation(fields: [commissionId], references: [id])
  payment               Payment?        @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
}

model UserGrant {
  id            String    @id @default(cuid())
  userId        String
  grantType     GrantType
  usedAt        DateTime?
  expiresAt     DateTime?
  grantedBy     String
  createdAt     DateTime  @default(now())
  grantedByUser User      @relation("GrantedBy", fields: [grantedBy], references: [id])
  user          User      @relation("GrantRecipient", fields: [userId], references: [id])

  @@index([userId, usedAt])
  @@index([grantedBy])
}

model Payment {
  id               String            @id @default(cuid())
  transactionId    String
  gateway          PaymentGateway
  method           PaymentMethod
  amount           Int
  currency         String            @default("HKD")
  status           PaymentStatus     @default(PENDING)
  description      String?
  metadata         Json              @default("{}")
  commissionId     String?
  completedAt      DateTime?
  failedAt         DateTime?
  refundedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  hostingTransfers HostingTransfer[]
  commission       Commission?       @relation(fields: [commissionId], references: [id])

  @@unique([transactionId, gateway])
  @@index([commissionId])
  @@index([status])
  @@index([gateway])
  @@index([method])
  @@index([createdAt])
}

model ClientPreference {
  id               String     @id @default(cuid())
  commissionId     String     @unique
  locale           String     @default("en")
  slackWebhookUrl  String?
  maintenanceOptIn Boolean    @default(false)
  commission       Commission @relation(fields: [commissionId], references: [id])
}

model Notification {
  id           String              @id @default(cuid())
  commissionId String
  event        NotificationEvent
  channel      NotificationChannel
  subject      String
  bodySnapshot String
  metadata     Json?
  sentAt       DateTime            @default(now())
  commission   Commission          @relation(fields: [commissionId], references: [id])
}

model DeliveryPackage {
  id          String   @id @default(cuid())
  buildId     String   @unique
  githubUrl   String
  hostingUrl  String?
  adrDocument String
  howToGuide  String
  apiDocs     String?
  videoUrl    String?
  assembledAt DateTime @default(now())
  build       Build    @relation(fields: [buildId], references: [id])
}

model Feedback {
  id           String     @id @default(cuid())
  commissionId String
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())
  commission   Commission @relation(fields: [commissionId], references: [id])
}

model MaintenancePlan {
  id              String     @id @default(cuid())
  commissionId    String     @unique
  githubUrl       String
  lastCheckAt     DateTime?
  nextCheckAt     DateTime?
  dependencyState Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  commission      Commission @relation(fields: [commissionId], references: [id])
}

model Credential {
  id              String     @id @default(cuid())
  commissionId    String
  service         String
  encryptedTokens String
  nonce           String?
  keyId           String?
  rotationDate    DateTime?
  commission      Commission @relation(fields: [commissionId], references: [id])

  @@unique([commissionId, service])
}

model MonitoringAlert {
  id         String        @id @default(cuid())
  priority   AlertPriority
  category   AlertCategory
  studio     String?
  title      String
  details    Json?
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([priority, createdAt])
  @@index([category, createdAt])
  @@index([resolvedAt])
}

model StudioMetrics {
  id                 String   @id @default(cuid())
  studioId           String
  studioName         String
  cpuPercent         Float
  ramPercent         Float
  diskPercent        Float
  networkIn          Float
  networkOut         Float
  queueDepth         Int      @default(0)
  createdAt          DateTime @default(now())
  containerCount     Int      @default(0)
  workerRestartCount Int      @default(0)
  workerRunning      Boolean  @default(false)

  @@index([studioId, createdAt])
}

model ApiHealthSnapshot {
  id        String   @id @default(cuid())
  provider  String
  status    String
  latencyMs Int      @default(0)
  details   Json?
  createdAt DateTime @default(now())

  @@index([provider, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([createdAt])
}

model Delivery {
  id                   String         @id @default(cuid())
  commissionId         String
  buildId              String
  repoName             String
  githubOrg            String
  clientGithubUsername String?
  clientGithubOrg      String?
  status               DeliveryStatus @default(VALIDATING)
  repoUrl              String?
  transferredRepoUrl   String?
  inviteId             Int?
  inviteRetryCount     Int            @default(0)
  secretScanPassed     Boolean        @default(false)
  bmadChecksPassed     Boolean        @default(false)
  contractCheckPassed  Boolean        @default(false)
  deliverables         Json?
  auditLog             Json           @default("[]")
  errorMessage         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  build                Build          @relation(fields: [buildId], references: [id])
  commission           Commission     @relation(fields: [commissionId], references: [id])
}

enum Role {
  CLIENT
  ENGINEER
  ADMIN
}

enum AgeTier {
  MINOR
  ADULT
}

enum ProjectStatus {
  DISCOVERY
  REVIEW
  CONTRACTED
  DEVELOPMENT
  VERIFICATION
  DELIVERED
  CANCELLED
}

enum ServiceTier {
  VIBE
  VERIFIED
  FOUNDRY
}

enum SafetyTier {
  GREEN
  YELLOW
  RED
}

enum ArchTemplate {
  SERVERLESS_SAAS
  MONOLITHIC_MVP
  MICROSERVICES_SCALE
}

enum CommissionStatus {
  DRAFT
  DISCOVERY
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ESCALATED
}

enum NotificationChannel {
  EMAIL
  SLACK
  SMS
  PHONE
}

enum NotificationEvent {
  BUILD_STARTED
  BUILD_PROGRESS
  BUILD_COMPLETE
  TRANSFER_READY
  SUPPORT_REQUIRED
  FEEDBACK_REQUEST
  MAINTENANCE_REPORT
  FARM_ALERT
}

enum PaymentState {
  UNPAID
  PARTIAL
  FINAL
}

enum AgentType {
  DATABASE
  BACKEND
  FRONTEND
  DEVOPS
  QA
  COORDINATOR
}

enum PaymentGateway {
  STRIPE
  PAYMENTASIA
}

enum PaymentMethod {
  CARD
  FPS
  ALIPAYHK
  WECHATPAY
  PAYME
  OCTOPUS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum RepoSurgeryStatus {
  INGESTING
  VECTORIZING
  ANALYZING
  MODIFYING
  VALIDATING
  REVIEWING
  COMPLETED
  FAILED
  HALTED
}

enum TransferStatus {
  PENDING_PAYMENT
  PAYMENT_CONFIRMED
  DEPLOYING
  DEPLOYED
  TRANSFERRING
  COMPLETED
  FAILED
  MONITORING
}

enum HostingProvider {
  VERCEL
  RAILWAY
  RENDER
  AWS
  GCP
  SELF_HOSTED
}

enum GrantType {
  UNLIMITED_7DAY
  FREE_SOURCE
  FREE_SOURCE_OR_DEPLOY
}

enum AlertPriority {
  P0
  P1
  P2
}

enum AlertCategory {
  RESOURCE
  API
  BUILD
  SECURITY
  BACKUP
}

enum DeliveryStatus {
  VALIDATING
  CREATING_REPO
  GENERATING_DOCS
  TRANSFERRING
  AWAITING_ACCEPTANCE
  VERIFYING
  COMPLETED
  FAILED
  ROLLBACK
}
