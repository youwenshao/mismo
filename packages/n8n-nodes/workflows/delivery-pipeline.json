        "buildId": "={{ $node['Webhook Trigger'].json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 2,
        "initialBackoffMs": 3000
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000008",
      "name": "Post-Transfer Verify Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [1900, 100]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "pipelineStatus",
              "value": "COMPLETED"
            },
            {
              "name": "message",
              "value": "Delivery pipeline completed successfully"
            }
          ]
        }
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000009",
      "name": "Set Success",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2200, 100]
    },
    {
      "parameters": {
        "buildId": "={{ $node['Webhook Trigger'].json.body.buildId }}",
        "stage": "delivery-pipeline",
        "status": "FAILED",
        "output": "={{ JSON.stringify({ error: 'Pre-transfer validation failed', blockers: $node['Pre-Transfer Validation Retry'].json.result.blockers }) }}"
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000010",
      "name": "Log Validation Failure",
      "type": "n8n-nodes-mismo.errorLogger",
      "typeVersion": 1,
      "position": [800, 450]
    },
    {
      "parameters": {
