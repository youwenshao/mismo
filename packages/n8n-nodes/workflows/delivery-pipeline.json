        "stage": "delivery-pipeline",
        "status": "FAILED",
        "output": "={{ JSON.stringify({ error: 'Transfer failed', details: $json.result }) }}"
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000012",
      "name": "Log Transfer Failure",
      "type": "n8n-nodes-mismo.errorLogger",
