{
  "name": "Delivery Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "delivery-pipeline",
        "responseMode": "lastNode"
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000001",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 300],
      "webhookId": "delivery-pipeline"
    },
    {
      "parameters": {
        "serviceUrl": "={{ (process.env.DELIVERY_AGENT_URL || 'http://localhost:3001') + '/api/delivery/validate' }}",
        "requestBody": "={{ JSON.stringify({ buildId: $json.body.buildId, commissionId: $json.body.commissionId, workspaceDir: $json.body.workspaceDir, buildStatus: $json.body.buildStatus || 'SUCCESS', commissionStatus: $json.body.commissionStatus || 'COMPLETED', apiContracts: $json.body.apiContracts, implementedRoutes: $json.body.implementedRoutes }) }}",
        "buildId": "={{ $json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 2,
        "initialBackoffMs": 1000
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000002",
      "name": "Pre-Transfer Validation Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.result.allPassed }}",
              "value2": true
            }
          ]
        }
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000003",
      "name": "Validation Passed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [550, 300]
    },
    {
      "parameters": {
        "serviceUrl": "={{ (process.env.DELIVERY_AGENT_URL || 'http://localhost:3001') + '/api/delivery/create-repo' }}",
        "requestBody": "={{ JSON.stringify({ buildId: $node['Webhook Trigger'].json.body.buildId, commissionId: $node['Webhook Trigger'].json.body.commissionId, repoName: $node['Webhook Trigger'].json.body.repoName, githubOrg: $node['Webhook Trigger'].json.body.githubOrg, workspaceDir: $node['Webhook Trigger'].json.body.workspaceDir, templateId: $node['Webhook Trigger'].json.body.templateId }) }}",
        "buildId": "={{ $node['Webhook Trigger'].json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 3,
        "initialBackoffMs": 2000
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000004",
      "name": "Repo Creator Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [800, 200]
    },
    {
      "parameters": {
        "serviceUrl": "={{ (process.env.DELIVERY_AGENT_URL || 'http://localhost:3001') + '/api/delivery/generate-docs' }}",
        "requestBody": "={{ JSON.stringify({ buildId: $node['Webhook Trigger'].json.body.buildId, commissionId: $node['Webhook Trigger'].json.body.commissionId, prdJson: $node['Webhook Trigger'].json.body.prdJson, repoOwner: $json.result.repoOwner, repoName: $json.result.repoName }) }}",
        "buildId": "={{ $node['Webhook Trigger'].json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 2,
        "initialBackoffMs": 1000
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000005",
      "name": "Doc Generator Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [1100, 200]
    },
    {
      "parameters": {
        "serviceUrl": "={{ (process.env.DELIVERY_AGENT_URL || 'http://localhost:3001') + '/api/delivery/transfer' }}",
        "requestBody": "={{ JSON.stringify({ deliveryId: $node['Webhook Trigger'].json.body.deliveryId, clientGithubUsername: $node['Webhook Trigger'].json.body.clientGithubUsername, clientGithubOrg: $node['Webhook Trigger'].json.body.clientGithubOrg, repoUrl: $node['Repo Creator Retry'].json.result.repoUrl, repoOwner: $node['Repo Creator Retry'].json.result.repoOwner, repoName: $node['Repo Creator Retry'].json.result.repoName }) }}",
        "buildId": "={{ $node['Webhook Trigger'].json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 3,
        "initialBackoffMs": 5000
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000006",
      "name": "Transfer Agent Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [1400, 200]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.result.success }}",
              "value2": true
            }
          ]
        }
      },
      "id": "d1e2f3a4-0001-4000-8000-000000000007",
      "name": "Transfer Succeeded?",
