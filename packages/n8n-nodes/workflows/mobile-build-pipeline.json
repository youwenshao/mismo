{
  "name": "Mobile Build Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mobile-build-pipeline",
        "responseMode": "lastNode"
      },
      "id": "m0b1-0001-4000-8000-000000000001",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 300],
      "webhookId": "mobile-build-pipeline"
    },
    {
      "parameters": {
        "buildId": "={{ $json.body.buildId }}",
        "mobileConfig": "={{ JSON.stringify($json.body.prdJson.mobileConfig || {}) }}"
      },
      "id": "m0b1-0001-4000-8000-000000000002",
      "name": "Mobile Feasibility Checker",
      "type": "n8n-nodes-mismo.mobileFeasibilityChecker",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.halted }}",
              "value2": true
            }
          ]
        }
      },
      "id": "m0b1-0001-4000-8000-000000000003",
      "name": "Feasibility Gate",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "HALTED"
            },
            {
              "name": "buildId",
              "value": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}"
            },
            {
              "name": "message",
              "value": "={{ $node[\"Mobile Feasibility Checker\"].json.haltReason }}"
            },
            {
              "name": "score",
              "value": "={{ $node[\"Mobile Feasibility Checker\"].json.score }}"
            }
          ]
        },
        "options": {}
      },
      "id": "m0b1-0001-4000-8000-000000000004",
      "name": "Set Halted",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [750, 450]
    },
    {
      "parameters": {
        "operation": "parsePrd",
        "buildId": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}",
        "prdJson": "={{ $node[\"Webhook Trigger\"].json.body.prdJson }}"
      },
      "id": "m0b1-0001-4000-8000-000000000005",
      "name": "GSD Dependency Checker",
      "type": "n8n-nodes-mismo.gsdDependencyChecker",
      "typeVersion": 1,
      "position": [750, 200]
    },
    {
      "parameters": {
        "serviceUrl": "http://mobile-scaffold:3020/generate",
        "requestBody": "={{ JSON.stringify({ projectName: $node[\"Webhook Trigger\"].json.body.prdJson.projectName, bundleId: $node[\"Webhook Trigger\"].json.body.prdJson.bundleId, prd: $node[\"Webhook Trigger\"].json.body.prdJson, designDna: $node[\"Webhook Trigger\"].json.body.prdJson.designDna || {}, architectureDecision: $node[\"Mobile Feasibility Checker\"].json.architectureDecision }) }}",
        "buildId": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 3,
        "initialBackoffMs": 1000
      },
      "id": "m0b1-0001-4000-8000-000000000006",
      "name": "Mobile Scaffold Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [1050, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ (process.env.CONTRACT_CHECKER_URL || 'http://contract-checker:3012') + '/check-mobile-architecture' }}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "buildId",
              "value": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}"
            },
            {
              "name": "architectureDecision",
              "value": "={{ $node[\"Mobile Feasibility Checker\"].json.architectureDecision }}"
            },
            {
              "name": "buildOutput",
              "value": "={{ $node[\"Mobile Scaffold Retry\"].json.data }}"
            }
          ]
        },
        "options": {}
      },
      "id": "m0b1-0001-4000-8000-000000000007",
      "name": "Contract Check (Scaffold)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1350, 200]
    },
    {
      "parameters": {
        "serviceUrl": "http://mobile-feature:3021/generate",
        "requestBody": "={{ JSON.stringify({ scaffoldOutput: $node[\"Mobile Scaffold Retry\"].json.data, prd: $node[\"Webhook Trigger\"].json.body.prdJson, designDna: $node[\"Webhook Trigger\"].json.body.prdJson.designDna || {}, componentLibrary: $node[\"Webhook Trigger\"].json.body.prdJson.componentLibrary || 'react-native-paper' }) }}",
        "buildId": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 3,
        "initialBackoffMs": 1000
      },
      "id": "m0b1-0001-4000-8000-000000000008",
      "name": "Mobile Feature Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [1650, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ (process.env.CONTRACT_CHECKER_URL || 'http://contract-checker:3012') + '/check-mobile-architecture' }}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "buildId",
              "value": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}"
            },
            {
              "name": "architectureDecision",
              "value": "={{ $node[\"Mobile Feasibility Checker\"].json.architectureDecision }}"
            },
            {
              "name": "buildOutput",
              "value": "={{ $node[\"Mobile Feature Retry\"].json.data }}"
            }
          ]
        },
        "options": {}
      },
      "id": "m0b1-0001-4000-8000-000000000009",
      "name": "Contract Check (Feature)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1950, 200]
    },
    {
      "parameters": {
        "serviceUrl": "http://mobile-build-engineer:3022/generate",
        "requestBody": "={{ JSON.stringify({ projectPath: $node[\"Webhook Trigger\"].json.body.projectPath || '/tmp/mobile-build', platform: 'ios', buildProfile: 'production', credentials: $node[\"Webhook Trigger\"].json.body.credentials || {}, submitToStore: true }) }}",
        "buildId": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}",
        "httpMethod": "POST",
        "maxRetries": 2,
        "initialBackoffMs": 5000
      },
      "id": "m0b1-0001-4000-8000-000000000010",
      "name": "iOS Build Retry",
      "type": "n8n-nodes-mismo.gsdRetryWrapper",
      "typeVersion": 1,
      "position": [2250, 100]
    },
    {
      "parameters": {
        "serviceUrl": "http://mobile-build-engineer:3022/generate",
        "requestBody": "={{ JSON.stringify({ projectPath: $node[\"Webhook Trigger\"].json.body.projectPath || '/tmp/mobile-build', platform: 'android', buildProfile: 'production', credentials: $node[\"Webhook Trigger\"].json.body.credentials || {}, submitToStore: true }) }}",
