            },
            {
              "name": "clientBundleId",
              "value": "={{ $node[\"Webhook Trigger\"].json.body.prdJson.bundleId }}"
            }
          ]
        },
        "options": {}
      },
      "id": "m0b1-0001-4000-8000-000000000015",
      "name": "Bundle ID Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2900, 400]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $node[\"iOS Build Retry\"].json.data?.status === 'success' && $node[\"Android Build Retry\"].json.data?.status === 'success' }}",
              "value2": true
            }
          ]
        }
      },
      "id": "m0b1-0001-4000-8000-000000000016",
      "name": "All Builds Passed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [3200, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "SUCCESS"
