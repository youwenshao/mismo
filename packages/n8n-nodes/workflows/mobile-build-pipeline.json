            {
              "name": "buildId",
              "value": "={{ $node[\"Webhook Trigger\"].json.body.buildId }}"
            },
            {
              "name": "message",
              "value": "Mobile build pipeline completed. iOS and Android builds submitted."
            }
          ]
        },
        "options": {}
