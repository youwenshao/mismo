{
  "name": "@mismo/decidendi",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "compile": "npx hardhat compile",
    "test:sol": "forge test -vvv",
    "test:ts": "vitest run",
    "test": "forge test -vvv && vitest run",
    "deploy:sepolia": "npx hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:mainnet": "npx hardhat run scripts/deploy.ts --network baseMainnet",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-foundry": "^1.1.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^3.0.0",
    "@nomicfoundation/hardhat-viem": "^2.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/node": "^20.10.0",
    "hardhat": "^2.22.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
