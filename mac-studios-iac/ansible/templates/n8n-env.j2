# ==========================================
# n8n High-Availability Orchestrator
# Generated by Ansible for {{ inventory_hostname }}
# ==========================================

# Shared Encryption Key
N8N_ENCRYPTION_KEY={{ n8n_encryption_key }}

# PostgreSQL Configuration
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}

# Redis Configuration
REDIS_PASSWORD={{ redis_password }}

{% if 'control_plane' in group_names %}
# ==========================================
# Studio 1 (Control Plane) - Main Node
# ==========================================
N8N_HOST={{ n8n_host }}
GENERIC_TIMEZONE={{ generic_timezone }}

# n8n Admin Credentials
N8N_ADMIN_EMAIL={{ n8n_admin_email }}
N8N_ADMIN_PASSWORD={{ n8n_admin_password }}

OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true

# Supabase (Mapped from root .env)
SUPABASE_URL={{ root_supabase_url }}
SUPABASE_SERVICE_ROLE_KEY={{ root_supabase_service_role_key }}

# Farm Monitor
STUDIO_1_SSH_HOST={{ hostvars['studio-1'].ansible_host }}
STUDIO_2_SSH_HOST={{ hostvars['studio-2'].ansible_host }}
STUDIO_3_SSH_HOST={{ hostvars['studio-3'].ansible_host }}
SSH_USER=admin

# AI Providers (Failover/Checks)
KIMI_API_KEY={{ root_kimi_api_key }}
DEEPSEEK_API_KEY={{ root_deepseek_api_key }}
GITHUB_TOKEN={{ root_github_token }}

{% else %}
# ==========================================
# Studio 2 & 3 (Execution Plane) - Worker Nodes
# ==========================================
# IP Address of Studio 1 (Main Node)
MAIN_NODE_IP={{ hostvars['studio-1'].ansible_host }}

# Redis Auto-reconnection & Queue configuration
QUEUE_BULL_REDIS_HOST={{ hostvars['studio-1'].ansible_host }}
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD={{ redis_password }}
QUEUE_BULL_REDIS_TIMEOUT=30000

# Database Connection for Worker
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST={{ hostvars['studio-1'].ansible_host }}
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE={{ postgres_db }}
DB_POSTGRESDB_USER={{ postgres_user }}
DB_POSTGRESDB_PASSWORD={{ postgres_password }}

# Supabase (Mapped from root .env)
SUPABASE_URL={{ root_supabase_url }}
SUPABASE_SERVICE_ROLE_KEY={{ root_supabase_service_role_key }}

OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
{% endif %}
