# ==========================================
# n8n High-Availability Orchestrator
# Shared Environment Variables
# ==========================================

# Use the same encryption key across all nodes (Main, Worker 1, Worker 2)
# You can generate one using: openssl rand -hex 16
N8N_ENCRYPTION_KEY=your_shared_encryption_key_here

# PostgreSQL Configuration (Main Node only)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=n8n

# Redis Configuration (Used by Queue Mode)
REDIS_PASSWORD=your_redis_password

# ==========================================
# Studio 1 (M4 Max) - Main Node
# ==========================================
N8N_HOST=n8n.yourdomain.com
GENERIC_TIMEZONE=America/New_York

# n8n Admin Credentials (change before first launch!)
N8N_ADMIN_EMAIL=admin@mismo.dev
N8N_ADMIN_PASSWORD=CHANGE_ME_BEFORE_LAUNCH
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ==========================================
# Studio 2 & 3 (M2 Ultra) - Worker Nodes
# ==========================================
# IP Address or hostname of the Studio 1 (Main Node)
MAIN_NODE_IP=192.168.1.100

# Redis Auto-reconnection & Queue configuration
# 30 seconds timeout to handle transient drops between Studios
QUEUE_BULL_REDIS_TIMEOUT=30000

# ==========================================
# Delivery Pipeline (GitHub source code transfer)
# ==========================================
# Required for delivery workflow; set in n8n or agent environment
# GITHUB_TOKEN=ghp_...
# GITHUB_DELIVERY_ORG=mismo-agency
# DELIVERY_AGENT_URL=http://internal-app:3001

# ==========================================
# Farm Monitor (Agent farm monitoring; Studio 1 only)
# ==========================================
STUDIO_1_SSH_HOST=192.168.1.101
STUDIO_2_SSH_HOST=192.168.1.102
STUDIO_3_SSH_HOST=192.168.1.103
SSH_USER=admin
# SSH keys mounted from host ~/.ssh into container /root/.ssh

# API keys for health checks (Kimi failover, GitHub rate limit)
# KIMI_API_KEY=
# DEEPSEEK_API_KEY=
# GITHUB_TOKEN=

# Alerts (P0: SMS+Phone; P1: Slack+Email; P2: Dashboard only)
SLACK_ALERT_WEBHOOK_URL=
ALERT_EMAIL=
ALERT_PHONE_NUMBER=

# Twilio (P0 critical: SMS and phone call)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Resend (P1 email; optional if RESEND_API_KEY set in root .env)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=alerts@mismo.dev
